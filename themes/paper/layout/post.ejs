<% var hasToc = page.content && /<h[2-4]/.test(page.content); %>
<div class="post-layout <%= hasToc ? 'has-toc' : '' %>">
  <article class="post">
    <header class="post-header">
      <h1 class="post-title"><%= page.title %></h1>
      <div class="post-meta">
        <% if (page.date) { %>
          <time datetime="<%= page.date.toISOString() %>"><%= page.date.format(theme.date_format || 'YYYY.MM.DD') %></time>
        <% } %>
        <% if (page.categories && page.categories.length) { %>
          <span class="dot">·</span>
          <% page.categories.each(function (cat) { %>
            <a class="chip chip-cat" href="<%- url_for(cat.path) %>"><%= cat.name %></a>
          <% }) %>
        <% } %>
        <% if (page.tags && page.tags.length) { %>
          <span class="dot">·</span>
          <% page.tags.each(function (tag) { %>
            <a class="chip" href="<%- url_for(tag.path) %>"># <%= tag.name %></a>
          <% }) %>
        <% } %>
      </div>
    </header>
    <div class="prose">
      <%- page.content %>
    </div>
    <% if (page.prev || page.next) { %>
      <nav class="post-nav">
        <% if (page.prev) { %>
          <a class="prev" href="<%- url_for(page.prev.path) %>">
            <div class="label">← 上一篇</div>
            <div class="post-nav-title"><%= page.prev.title %></div>
          </a>
        <% } else { %>
          <span></span>
        <% } %>
        <% if (page.next) { %>
          <a class="next" href="<%- url_for(page.next.path) %>">
            <div class="label">下一篇 →</div>
            <div class="post-nav-title"><%= page.next.title %></div>
          </a>
        <% } else { %>
          <span></span>
        <% } %>
      </nav>
    <% } %>
    <% if (config.Gitalk && config.Gitalk.enable) { %>
      <div id="gitalk-container"></div>
    <% } %>
  </article>
  <%- partial('_partial/toc') %>
</div>
