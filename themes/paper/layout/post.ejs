<%
  var postBodyContent = page.excerpt ? page.more : page.content;
%>
<section class="paper-grid post-paper-grid">
  <aside class="coordinate-rail" aria-hidden="true">
    <div class="coordinate-sticky">
      <span class="coordinate-symbol">READ</span>
      <span class="coordinate-progress" data-read-progress>00</span>
    </div>
  </aside>

  <article class="post reading-column">
    <header class="post-header">
      <h1 class="post-title"><%= page.title %></h1>
      <div class="post-meta">
        <% if (page.date) { %>
          <time datetime="<%= page.date.toISOString() %>"><%= page.date.format(theme.date_format || 'YYYY.MM.DD') %></time>
        <% } %>
        <% if (page.categories && page.categories.length) { %>
          <span class="dot">·</span>
          <% page.categories.each(function (cat) { %>
            <a class="chip chip-cat" href="<%- url_for(cat.path) %>"><%= cat.name %></a>
          <% }) %>
        <% } %>
        <% if (page.tags && page.tags.length) { %>
          <span class="dot">·</span>
          <% page.tags.each(function (tag) { %>
            <a class="chip" href="<%- url_for(tag.path) %>"># <%= tag.name %></a>
          <% }) %>
        <% } %>
      </div>
      <% if (page.excerpt && page.more) { %>
        <div class="post-deck prose" data-post-excerpt>
          <%- page.excerpt %>
        </div>
      <% } %>
    </header>
    <div class="prose post-content" data-post-content>
      <%- postBodyContent %>
      <% if ((page.categories && page.categories.length) || (page.tags && page.tags.length)) { %>
        <footer class="post-meta-footer" aria-label="文章分类与标签">
          <% if (page.categories && page.categories.length) { %>
            <div class="footer-meta-group footer-categories">
              <% page.categories.each(function (cat) { %>
                <a class="footer-category" href="<%- url_for(cat.path) %>"><%= cat.name %></a>
              <% }) %>
            </div>
          <% } %>
          <% if (page.tags && page.tags.length) { %>
            <div class="footer-meta-group footer-tags">
              <% page.tags.each(function (tag) { %>
                <a class="tag-fingerprint" href="<%- url_for(tag.path) %>" data-tag-filter="<%= tag.name %>">#<%= tag.name %></a>
              <% }) %>
            </div>
          <% } %>
        </footer>
      <% } %>
    </div>
    <% if (page.prev || page.next) { %>
      <nav class="post-nav">
        <% if (page.prev) { %>
          <a class="prev" href="<%- url_for(page.prev.path) %>">
            <div class="label">← 上一篇</div>
            <div class="post-nav-title"><%= page.prev.title %></div>
          </a>
        <% } else { %>
          <span></span>
        <% } %>
        <% if (page.next) { %>
          <a class="next" href="<%- url_for(page.next.path) %>">
            <div class="label">下一篇 →</div>
            <div class="post-nav-title"><%= page.next.title %></div>
          </a>
        <% } else { %>
          <span></span>
        <% } %>
      </nav>
    <% } %>
    <% if ((theme.gitalk && theme.gitalk.enable) || (config.Gitalk && config.Gitalk.enable)) { %>
      <div id="gitalk-container"></div>
    <% } %>
  </article>

  <aside class="right-void">
    <div class="right-void-inner"></div>
  </aside>
</section>
