<head>
  <%
    var gitalkConfig = theme.gitalk || config.Gitalk || {};
    var gitalkEnabled = !!gitalkConfig.enable;
    var gitalkClientId = gitalkConfig.client_id || gitalkConfig.clientID || '';
    var gitalkClientSecret = gitalkConfig.client_secret || gitalkConfig.clientSecret || '';
  %>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title>
    <% if (page.title && page.title !== config.title) { %><%= page.title %> · <% } %><%= config.title %>
  </title>
  <% if (config.description) { %>
    <meta name="description" content="<%= config.description %>">
  <% } %>
  <% if (config.keywords) { %>
    <meta name="keywords" content="<%= config.keywords %>">
  <% } %>
  <% if (config.author) { %>
    <meta name="author" content="<%= config.author %>">
  <% } %>
  <link rel="icon" href="<%- url_for('/imgs/favicon.ico') %>">
  <link rel="stylesheet" href="<%- url_for('/css/style.css') %>">
  <% if (theme.highlight && theme.highlight.enable) { %>
    <link rel="stylesheet" href="<%- url_for('/plugins/highlight/styles/' + theme.highlight.theme + '.css') %>">
  <% } %>
  <script>
    // Apply stored theme before first paint — avoids FOUC
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') {
          document.documentElement.setAttribute('data-theme', t);
        }
      } catch (e) {}
    })();
  </script>
  <% if (gitalkEnabled) { %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gitalk@1/dist/gitalk.css">
    <script src="https://cdn.jsdelivr.net/npm/gitalk@1/dist/gitalk.min.js"></script>
    <script>
      window.addEventListener('load', function () {
        var el = document.getElementById('gitalk-container');
        if (!el) return;
        var gitalk = new Gitalk({
          clientID: '<%= gitalkClientId %>',
          clientSecret: '<%= gitalkClientSecret %>',
          repo: '<%= gitalkConfig.repo || '' %>',
          owner: '<%= gitalkConfig.owner || '' %>',
          admin: ['<%= gitalkConfig.admin || '' %>'],
          id: location.pathname,
          distractionFreeMode: false
        });
        gitalk.render('gitalk-container');
      });
    </script>
  <% } %>
</head>
