// layout — nav / main / footer skeleton

// ---- Header: three-column centered nav ----
.header-container
  max-width var(--content-width)
  margin 0 auto
  padding 3rem var(--sp-6) 4rem
  display flex
  justify-content space-between
  align-items center

// Left and right slots share equal width so the nav stays dead-centre
.header-left-spacer,
.header-right-controls
  width 50px
  display flex

.header-right-controls
  justify-content flex-end

.main-nav
  display flex
  gap 2.5rem

.nav-item
  color var(--fg-muted)
  font-size 1rem
  letter-spacing 0.02em
  text-decoration none
  transition color 0.3s ease
  padding-bottom 4px

.nav-item:hover
  color var(--fg)

.nav-item.active
  color var(--fg-heading)
  font-weight 600
  border-bottom 2px solid var(--border-strong)

.main
  flex 1
  width 100%
  padding var(--sp-2) var(--sp-6) 0

.site-footer
  margin-top var(--sp-20)
  border-top 1px solid var(--border)
  padding var(--sp-10) var(--sp-6)
  text-align center
  font-size 13px
  color var(--fg-subtle)
  line-height 1.8

.site-footer a
  color var(--fg-muted)

.site-footer a:hover
  color var(--accent)

.site-footer .footer-row
  margin-bottom var(--sp-2)

.site-footer .footer-row:last-child
  margin-bottom 0
