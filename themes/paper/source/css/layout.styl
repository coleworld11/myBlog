// layout — nav / main / footer skeleton

.site-header
  border-bottom 1px solid var(--border)
  background var(--bg)

.nav
  max-width var(--layout-width)
  margin 0 auto
  padding var(--sp-6) var(--sp-8)
  display flex
  align-items center
  justify-content space-between
  gap var(--sp-6)

.nav-brand
  font-size 1.25rem
  font-weight 600
  color var(--fg)
  letter-spacing 0.1em
  transition opacity var(--transition-base)

.nav-brand::after
  content '.'
  margin-left 2px
  color var(--accent)
  font-weight 700
  letter-spacing 0

.nav-brand:hover
  color var(--fg)
  opacity 0.7

.nav-menu
  display flex
  align-items center
  gap var(--sp-6)
  flex-wrap wrap

.nav-menu a
  font-size 14px
  font-weight 500
  color var(--fg-muted)
  position relative
  padding var(--sp-1) 0

.nav-menu a:hover
  color var(--fg-heading)

.nav-menu a.active
  color var(--fg-heading)

.nav-menu a.active::after
  content ''
  position absolute
  left 0
  right 0
  bottom -4px
  height 2px
  background var(--accent)

.main
  flex 1
  width 100%
  padding var(--sp-12) var(--sp-8)

.site-footer
  margin-top var(--sp-20)
  border-top 1px solid var(--border)
  padding var(--sp-10) var(--sp-6)
  text-align center
  font-size 13px
  color var(--fg-subtle)
  line-height 1.8

.site-footer a
  color var(--fg-muted)

.site-footer a:hover
  color var(--accent)

.site-footer .footer-row
  margin-bottom var(--sp-2)

.site-footer .footer-row:last-child
  margin-bottom 0
