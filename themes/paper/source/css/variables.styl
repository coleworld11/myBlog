:root
  --bg-color #F9F8F6
  --text-main #2D2D2D
  --text-muted #8C8A85
  --border-color #EBE8E2
  --accent-color #3B66F5
  --code-bg #F2EFE9
  --surface-color rgba(255, 255, 255, 0.42)
  --surface-strong #FFFFFF
  --text-heading #202020
  --text-subtle #B4B0A8
  --border-strong #DCD7CC
  --accent-hover #234AD1
  --accent-soft rgba(59, 102, 245, 0.08)
  --selection-bg rgba(59, 102, 245, 0.16)

  --bg var(--bg-color)
  --bg-elevated var(--surface-strong)
  --fg var(--text-main)
  --fg-heading var(--text-heading)
  --fg-muted var(--text-muted)
  --fg-subtle var(--text-subtle)
  --border var(--border-color)
  --accent var(--accent-color)
  --accent-bg var(--accent-soft)
  --accent-bg-hover rgba(59, 102, 245, 0.14)
  --code-fg var(--text-main)
  --code-inline-bg #ECE8DF

  --font-serif Georgia, 'Noto Serif SC', SimSun, serif
  --font-sans 'Avenir Next', 'Gill Sans', 'PingFang SC', 'Source Han Sans SC', 'Microsoft YaHei', sans-serif
  --font-mono 'JetBrains Mono', 'Fira Code', Consolas, 'Liberation Mono', monospace

  --sp-1  4px
  --sp-2  8px
  --sp-3  12px
  --sp-4  16px
  --sp-5  20px
  --sp-6  24px
  --sp-8  32px
  --sp-10 40px
  --sp-12 48px
  --sp-15 60px
  --sp-16 64px
  --sp-20 80px

  --content-width   680px
  --layout-width    1180px
  --rail-width      minmax(56px, 9vw)
  --void-width      minmax(220px, 34vw)

  --radius-sm 2px
  --radius-md 4px
  --radius-lg 8px
  --radius-pill 999px

  --lh-tight   1.35
  --lh-normal  1.75
  --lh-relaxed 1.8

  --transition-base 200ms ease
  --transition-slow 460ms cubic-bezier(0.22, 1, 0.36, 1)

@media (prefers-color-scheme: dark)
  :root
    --bg-color #1A1A18
    --text-main #E3E1DC
    --text-muted #706E6A
    --border-color #2E2E2C
    --accent-color #5C82FF
    --code-bg #20201E
    --surface-color rgba(32, 32, 30, 0.62)
    --surface-strong #20201E
    --text-heading #F0EEE8
    --text-subtle #5D5B56
    --border-strong #3A3A36
    --accent-hover #86A2FF
    --accent-soft rgba(92, 130, 255, 0.12)
    --selection-bg rgba(92, 130, 255, 0.22)
    --accent-bg-hover rgba(92, 130, 255, 0.2)
    --code-fg var(--text-main)
    --code-inline-bg #282823

html[data-theme='light']
  --bg-color #F9F8F6
  --text-main #2D2D2D
  --text-muted #8C8A85
  --border-color #EBE8E2
  --accent-color #3B66F5
  --code-bg #F2EFE9
  --surface-color rgba(255, 255, 255, 0.42)
  --surface-strong #FFFFFF
  --text-heading #202020
  --text-subtle #B4B0A8
  --border-strong #DCD7CC
  --accent-hover #234AD1
  --accent-soft rgba(59, 102, 245, 0.08)
  --selection-bg rgba(59, 102, 245, 0.16)
  --accent-bg-hover rgba(59, 102, 245, 0.14)
  --code-fg var(--text-main)
  --code-inline-bg #ECE8DF

html[data-theme='dark']
  --bg-color #1A1A18
  --text-main #E3E1DC
  --text-muted #706E6A
  --border-color #2E2E2C
  --accent-color #5C82FF
  --code-bg #20201E
  --surface-color rgba(32, 32, 30, 0.62)
  --surface-strong #20201E
  --text-heading #F0EEE8
  --text-subtle #5D5B56
  --border-strong #3A3A36
  --accent-hover #86A2FF
  --accent-soft rgba(92, 130, 255, 0.12)
  --selection-bg rgba(92, 130, 255, 0.22)
  --accent-bg-hover rgba(92, 130, 255, 0.2)
  --code-fg var(--text-main)
  --code-inline-bg #282823
