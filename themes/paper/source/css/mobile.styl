// mobile — collapse paper grid and keep controls reachable

@media (max-width: 1080px)
  .paper-grid
    grid-template-columns minmax(52px, 68px) minmax(0, var(--content-width))
    gap clamp(16px, 3vw, 28px)
    max-width 860px

  .ambient-nav
    padding 22px clamp(18px, 5vw, 34px)
    max-width none

  .timeline-page
    grid-template-columns minmax(52px, 68px) minmax(0, 1fr)
    gap clamp(16px, 3vw, 28px)
    max-width 920px

  .nav-container
    grid-template-columns minmax(42px, 1fr) auto minmax(42px, 1fr)

  .nav-links
    justify-content center

  .right-void
    display none

  .main-container
    padding-top 104px

  .paper-grid .reading-column,
  .timeline-page .reading-column
    grid-column 2 / 3
    max-width none

  .post-paper-grid,
  .page-paper-grid
    max-width 860px

@media (max-width: 760px)
  .timeline-page
    display block
    max-width var(--content-width)

  .coordinate-rail
    display none

  .timeline-page .reading-column
    max-width none

  .paper-grid
    display block

@media (max-width: 640px)
  .timeline-filter
    right 18px
    bottom 78px
    max-width calc(100vw - 36px)
    padding 9px 12px

  html
    font-size 15px

  .ambient-nav
    padding 18px 18px
    gap 14px

  .nav-links
    gap 18px

  .nav-link
    font-size 13px

  .avatar-logo-img
    width 30px
    height 30px

  .theme-toggle
    width 30px
    height 30px

  .main-container
    padding 92px 18px 0

  .timeline-year-mark
    min-height 72px

  .timeline-item
    padding 16px 0 20px

  .item-title
    font-size 1.5rem

  .timeline-item.is-active .item-title
    max-width none
    font-size 2.2rem

  .timeline-item.is-active
    max-width none

  .item-excerpt
    font-size 13px

  .post-title
    font-size 2.15rem

  .post-nav
    grid-template-columns 1fr

  .post-nav .next
    text-align left

  .drawer-trigger
    right 18px
    bottom 18px

  .drawer-panel
    width 100vw

  .pagination
    flex-wrap wrap

  .archive-row
    flex-direction column
    align-items flex-start
    gap 2px

@media (prefers-reduced-motion: reduce)
  *,
  *::before,
  *::after
    animation-duration 1ms !important
    transition-duration 1ms !important
    scroll-behavior auto !important
