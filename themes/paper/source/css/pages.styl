// pages — archive / tag / category / about

// ---- Shared page header ----
.page-head
  margin-bottom var(--sp-12)
  text-align center

.page-head h1
  font-size 2rem
  font-weight 700
  color var(--fg-heading)
  letter-spacing -0.02em
  margin 0 0 var(--sp-2)

.page-head .page-sub
  color var(--fg-muted)
  font-size 0.95rem
  letter-spacing 0.04em

// ---- Archive / timeline ----
.archive
  max-width var(--content-width)
  margin 0 auto

.archive-year
  margin var(--sp-12) 0 var(--sp-5)
  font-size 1.25rem
  font-weight 700
  color var(--fg-heading)
  letter-spacing -0.02em

.archive-year:first-child
  margin-top 0

.archive-row
  display flex
  align-items baseline
  gap var(--sp-5)
  padding var(--sp-2) 0
  color var(--fg)
  font-size 15px

.archive-date
  font-variant-numeric tabular-nums
  color var(--fg-muted)
  font-size 13px
  min-width 56px
  flex-shrink 0

.archive-title
  flex 1
  color var(--fg)
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  transition color var(--transition-base)

.archive-title:hover
  color var(--accent)

// ---- Category index (book-index style) ----
// Clean single-column list. Hover: page floats slightly right with
// a paper-white surface revealing underneath — like turning a page.
.category-index
  max-width 600px
  margin 0 auto
  display flex
  flex-direction column
  gap var(--sp-2)

.category-index-item
  display flex
  justify-content space-between
  align-items center
  padding var(--sp-4) var(--sp-6)
  border-radius var(--radius-md)
  color var(--fg)
  background transparent
  transition background-color var(--transition-base), transform var(--transition-base)

.category-index-item:hover
  background var(--bg-elevated)
  transform translateX(6px)

.category-index-item .name
  font-size 1.05rem
  font-weight 500

.category-index-item .count
  color var(--fg-subtle)
  font-family var(--font-mono)
  font-size 0.9rem
  font-variant-numeric tabular-nums

.category-index-item .count::before
  content '('
.category-index-item .count::after
  content ')'

// ---- Tag cloud (naked monochrome — air + typography, zero background) ----
.tag-cloud-naked
  display flex
  flex-wrap wrap
  gap 1.5rem 2.5rem
  justify-content center
  max-width 800px
  margin 3rem auto

.tag-item-naked
  display inline-flex
  align-items baseline
  padding 0
  background transparent
  border none
  text-decoration none
  position relative
  transition all 0.3s cubic-bezier(0.4, 0, 0.2, 1)

.tag-item-naked .tag-prefix
  color #D1D1D1
  font-size 0.85rem
  margin-right 0.15rem
  font-weight 300

.tag-item-naked .tag-name
  color #555555
  font-size 1.05rem
  font-weight 400
  letter-spacing 0.02em

.tag-item-naked .tag-count
  color #A0A0A0
  font-size 0.75rem
  margin-left 0.25rem
  font-weight 300

.tag-item-naked:hover .tag-name
  color #000000

.tag-item-naked:hover .tag-prefix,
.tag-item-naked:hover .tag-count
  color #888888

.tag-item-naked::after
  content ''
  position absolute
  bottom -4px
  left 0
  width 0%
  height 1px
  background-color #000000
  transition width 0.3s ease

.tag-item-naked:hover::after
  width 100%

// Dark mode — invert the gray scale
@media (prefers-color-scheme: dark)
  .tag-item-naked .tag-prefix
    color #5A5A5A
  .tag-item-naked .tag-name
    color #B0B0B0
  .tag-item-naked .tag-count
    color #6A6A6A
  .tag-item-naked:hover .tag-name
    color #FFFFFF
  .tag-item-naked:hover .tag-prefix,
  .tag-item-naked:hover .tag-count
    color #999999
  .tag-item-naked::after
    background-color #FFFFFF

html[data-theme='dark']
  .tag-item-naked .tag-prefix
    color #5A5A5A
  .tag-item-naked .tag-name
    color #B0B0B0
  .tag-item-naked .tag-count
    color #6A6A6A
  .tag-item-naked:hover .tag-name
    color #FFFFFF
  .tag-item-naked:hover .tag-prefix,
  .tag-item-naked:hover .tag-count
    color #999999
  .tag-item-naked::after
    background-color #FFFFFF

// ---- Single taxonomy (tag/category) — post list ----
.taxonomy-posts
  max-width var(--content-width)
  margin 0 auto

.taxonomy-posts .archive-row
  border-bottom 1px solid var(--border)

.taxonomy-posts .archive-row:last-child
  border-bottom none

// ---- About page ----
.about
  max-width var(--content-width)
  margin 0 auto
