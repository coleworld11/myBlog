// components — card / chip / pagination / toc / theme-toggle / post-nav

// ---- Home feed (article list + pagination wrapper) ----
// Caps to content-width so the stream feels focused on wide monitors,
// while detail pages with TOC still go full layout-width.
.feed
  max-width var(--content-width)
  margin 0 auto

// ---- Article list item (de-carded — whitespace-driven) ----
.card
  background transparent
  border none
  border-bottom 1px solid var(--border)
  border-radius 0
  padding 0
  margin-bottom var(--sp-15)

.card:last-child
  margin-bottom 0
  border-bottom none

.article-meta-top
  display flex
  align-items center
  gap var(--sp-3)
  color var(--fg-muted)
  font-size 13px
  margin-bottom var(--sp-2)

.article-meta-top time
  font-variant-numeric tabular-nums

.article-title
  font-size 1.75rem
  font-weight 700
  line-height var(--lh-tight)
  letter-spacing -0.02em
  margin 0 0 var(--sp-4)
  color var(--fg-heading)

.article-title a
  color inherit
  transition opacity var(--transition-base)

.article-title a:hover
  opacity 0.7
  color inherit

.article-excerpt
  color var(--fg)
  line-height var(--lh-relaxed)
  font-size 15px
  letter-spacing 0.01em
  max-width 65ch

.article-excerpt p
  margin 0

.article-excerpt p + p
  margin-top var(--sp-3)

.read-more
  margin-top var(--sp-5)

.read-more a
  display inline-flex
  align-items center
  gap 6px
  font-size 14px
  color var(--fg-muted)
  font-weight 500
  transition color var(--transition-base), transform var(--transition-base)

.read-more a:hover
  color var(--fg-heading)
  transform translateX(2px)

// ---- Chips (tags / categories) ----
.chip-list
  display flex
  flex-wrap wrap
  gap var(--sp-2)
  margin-top var(--sp-3)

.chip
  display inline-flex
  align-items center
  font-size 12px
  color var(--fg-muted)
  background var(--code-inline-bg)
  padding 3px 10px
  border-radius 6px
  transition color var(--transition-base), background var(--transition-base), transform var(--transition-base)

.chip .hash
  color var(--fg-subtle)
  margin-right 1px
  font-weight 400

.chip:hover
  color var(--fg-heading)
  background var(--border)
  transform translateY(-1px)

.chip.chip-cat
  color var(--fg-muted)
  font-weight 500
  background none
  padding 0

.chip.chip-cat:hover
  color var(--fg-heading)
  background none
  transform none

// ---- Pagination ----
.pagination
  display flex
  align-items center
  justify-content center
  gap var(--sp-3)
  margin-top var(--sp-16)
  padding-top var(--sp-8)
  border-top 1px solid var(--border)
  font-size 14px

.pagination a, .pagination span
  min-width 32px
  height 32px
  display inline-flex
  align-items center
  justify-content center
  padding 0 var(--sp-3)
  border 1px solid var(--border)
  border-radius var(--radius-sm)
  color var(--fg-muted)
  transition all var(--transition-base)

.pagination a:hover
  color var(--accent)
  border-color var(--accent)

.pagination .pagination-current
  background var(--accent)
  color #fff
  border-color var(--accent)

.pagination .pagination-ellipsis
  border none

// ---- Post layout (with TOC on wide screens) ----
// Default: narrow column for posts without TOC (pages, short posts)
// .has-toc: two-column grid with TOC sidebar on wide screens

.post-layout
  max-width var(--content-width)
  margin 0 auto

.post-layout.has-toc
  max-width var(--layout-width)
  display grid
  grid-template-columns minmax(0, var(--content-width)) 220px
  gap var(--sp-15)
  align-items start

.post
  min-width 0    // let flex/grid shrink when overflowing

.post-header
  margin-bottom var(--sp-10)

.post-title
  font-size 2.25rem
  font-weight 700
  line-height var(--lh-tight)
  letter-spacing -0.02em
  margin 0 0 var(--sp-3)

.post-meta
  display flex
  flex-wrap wrap
  align-items center
  gap var(--sp-3)
  font-size 13px
  color var(--fg-muted)

.post-meta time
  font-variant-numeric tabular-nums

.post-meta .dot
  color var(--fg-subtle)

// ---- TOC ----
.toc
  position sticky
  top var(--sp-8)
  max-height calc(100vh - var(--sp-16))
  overflow-y auto
  font-size 12px
  line-height 1.55

.toc-title
  font-weight 600
  color var(--fg-muted)
  margin-bottom var(--sp-3)
  font-size 11px
  text-transform uppercase
  letter-spacing 0.1em

.toc ol
  list-style none
  padding 0
  margin 0

.toc ol ol
  padding-left var(--sp-3)

.toc a
  display block
  padding var(--sp-1) var(--sp-2)
  color var(--fg-subtle)
  border-left 2px solid transparent
  margin-left -2px
  transition all var(--transition-base)
  // keep long titles single-line with ellipsis
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.toc a:hover
  color var(--fg)

.toc a.toc-active
  color var(--accent)
  border-left-color var(--accent)

// ---- Theme toggle ----
.theme-toggle
  background none
  border none
  color var(--fg-muted)
  cursor pointer
  padding 5px
  display inline-flex
  align-items center
  justify-content center
  transition color 0.3s ease, transform 0.4s cubic-bezier(0.4, 0, 0.2, 1)
  flex-shrink 0

.theme-toggle:hover
  color var(--fg)
  transform rotate(45deg)

.theme-toggle svg
  width 1.2rem
  height 1.2rem

.theme-toggle .theme-icon-light, .theme-toggle .theme-icon-dark
  display none

// Light icon is the default (shown when data-theme is unset or light)
.theme-toggle .theme-icon-light
  display block

html[data-theme='dark'] .theme-toggle .theme-icon-light
  display none

html[data-theme='dark'] .theme-toggle .theme-icon-dark
  display block

// ---- Post navigation (prev/next) ----
.post-nav
  margin-top var(--sp-12)
  padding-top var(--sp-6)
  border-top 1px solid var(--border)
  display grid
  grid-template-columns 1fr 1fr
  gap var(--sp-4)

.post-nav a
  display block
  padding var(--sp-4)
  border 1px solid var(--border)
  border-radius var(--radius-md)
  transition all var(--transition-base)

.post-nav a:hover
  border-color var(--accent)
  color inherit

.post-nav .label
  font-size 12px
  color var(--fg-muted)
  margin-bottom var(--sp-1)

.post-nav .post-nav-title
  color var(--fg-heading)
  font-weight 500

.post-nav .next
  text-align right

#gitalk-container
  margin-top var(--sp-12)
  padding-top var(--sp-6)
  border-top 1px solid var(--border)
